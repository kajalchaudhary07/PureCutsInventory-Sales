rules_version = '2';

// ---------------------------------------------------------------------------
// Super-admin-only inventory module.
// A signed-in user may read/write inventory data ONLY if a document with their
// UID exists in the "admins" collection (/admins/{theirUID}). This is the real
// server-side gate — the frontend login is never trusted on its own.
//
// Grant access:
//   1. Firebase console > Authentication > add the super-admin (email+password).
//   2. Copy their UID.
//   3. Firestore > collection "admins" > add a doc with Document ID == that UID.
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /products/{id}        { allow read, write: if isAdmin(); }
    match /itemGroups/{id}      { allow read, write: if isAdmin(); }
    match /salons/{id}          { allow read, write: if isAdmin(); }
    match /vendors/{id}         { allow read, write: if isAdmin(); }
    match /stockMovements/{id}  { allow read, write: if isAdmin(); }
    match /purchaseOrders/{id}  { allow read, write: if isAdmin(); }
    match /salesOrders/{id}     { allow read, write: if isAdmin(); }
    match /invoices/{id}        { allow read, write: if isAdmin(); }
    match /reports/{id}         { allow read, write: if isAdmin(); }
    match /activityLogs/{id}    { allow read, write: if isAdmin(); }

    // Admins read only their own record; manage this collection from the console.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
